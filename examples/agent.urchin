/// agent.urchin — seed corpus for urchin. file flow is small-to-large:
/// roles first (atomic creative activities), then the child actor
/// (creativePersona), then the parent actor (rubberDuck) at the bottom.
///
/// the topology: rubberDuck (a persona on the social-media simulation)
/// HAS a creativePersona (the slot that holds creative output). the
/// creativePersona composes three creative roles — photographer,
/// musician, director — each producing its own kind of output as the
/// world ticks.
///
/// state fields use init-required-and-inferred form: `name = init`.
/// no leading `~` (the `/// _state` marker carries the section identity);
/// no type annotation (inferred from init); collections are just
/// collections (no `[T]` annotation needed).
///
/// roles have NO interface methods. cross-role coordination happens via
/// broadcasts and message handlers; cross-IO interfaces (the protocol
/// each io.* module enforces) are a separate concern at the IO layer.

role photographer {
  /// _state
  shotsTaken = 0

  /// _handlers
  on tick -> int {
    shotsTaken = shotsTaken ~> shotsTaken + 1
    shotsTaken
  }
}

role musician {
  /// _state
  notesPlayed = 0

  /// _handlers
  on tick -> int {
    notesPlayed = notesPlayed ~> notesPlayed + 1
    notesPlayed
  }
}

role director {
  /// _state
  scenesDirected = 0

  /// _handlers
  on tick -> int {
    scenesDirected = scenesDirected ~> scenesDirected + 1
    scenesDirected
  }
}

actor creativePersona @ rubberDuck {
  /// _io
  clock: io.sim.clock

  /// _roles
  photographer(clock)
  musician(clock)
  director(clock)

  /// _dispatch_scripts
  on clock.tick parallel
}

actor rubberDuck {
  /// _io
  siblings: io.sim.comms.peer
}
