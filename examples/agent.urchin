/// agent.urchin — seed corpus for urchin. file flow is small-to-large:
/// roles first (atomic components), then the child actor (mind), then
/// the parent actor (rubberDuck) at the bottom. the reader builds up
/// intuition piece by piece.
///
/// roles and actors carry STRICT SECTION MARKERS — `/// _interface`,
/// `/// _state`, `/// _handlers` in roles; `/// _io`, `/// _roles`,
/// `/// _dispatch_scripts` in actors. markers make the structure
/// visible at the syntactic level. the parser tolerates them being
/// absent for legacy code, but idiomatic urchin always includes them.
///
/// state fields no longer carry the `~` prefix — the `/// _state`
/// section marker already says "everything below is state." mutations
/// still use `~>` (the journal hook earns its keep at the runtime side).
/// state fields can carry an optional `= init` default.

role hunger {
  /// _state
  level: float = 0.0

  /// _handlers
  on tick {
    level = level ~> level + 0.01
    if level > 0.7 {
      broadcast wants("food")
    }
  }
}

role episodicMemory {
  /// _interface
  record: event -> unit
  recall: cue -> [episode]

  /// _state
  episodes: [episode] = []

  /// _handlers
  on event e {
    episodes = episodes ~> episodes + [e]
  }

  on cue c {
    matches = episodes
      |> filter(by: c)
      |> rank(by: c.weight)
    reply matches
  }
}

role voice {
  /// _state
  mood: mood = calm

  /// _handlers
  on tick {
    match mood {
      calm     -> mood = mood ~> calm
      anxious  -> mood = mood ~> anxious
      excited  -> mood = mood ~> calm
      _        -> {}
    }
  }

  on wants need {
    mood = mood ~> anxious
  }
}

role listener {
  /// _state
  heard: [utterance] = []

  /// _handlers
  on utterance u {
    heard = heard ~> heard + [u]
  }
}

role prompter {
  /// _interface
  ask: utterance -> question / {io.anthropic.haiku}

  /// _state
  recentQuestion: question

  /// _handlers
  on utterance u {
    q = ask(u)
    recentQuestion = recentQuestion ~> q
    broadcast question(q)
  }
}

role mouth {
  /// _handlers
  on question q {}
}

actor mind @ rubberDuck {
  /// _io
  clock: io.sim.clock

  /// _roles
  episodicMemory(clock)
  voice(clock)(episodicMemory -> recall)
  hunger(clock)

  /// _dispatch_scripts
  on clock.tick sequence(hunger -> voice)
}

actor rubberDuck {
  /// _io
  llm:      io.anthropic.haiku
  siblings: io.sim.comms.peer

  /// _roles
  listener()
  prompter(llm)
  mouth()

  /// _dispatch_scripts
  on siblings.utterance sequence(listener -> prompter)
}
