/// io_llm.urchin — sketch of an LLM IO declaration.
///
/// the interface is the protocol — the shape of data crossing the
/// boundary. how it's actually implemented is a separate concern
/// (algebraic effect handlers will resolve it at runtime).

io llm {
  /// _requests
  ask(prompt: str) -> str

  /// _config
  model = "haiku"
  temperature = 0
}
